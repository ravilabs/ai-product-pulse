{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ravilabs/ai-product-pulse/blob/main/report.schema.json",
  "title": "AI Product Pulse Report",
  "description": "GENERATED FILE \u2014 DO NOT EDIT DIRECTLY. Produced from the Pydantic models in packages/python/src/ai_product_pulse/domain/entities.py by scripts/sync_report_schema.py. Validates the output of a feature-level or product-level triage run. A report is exactly one of FeatureReport or ProductReport, discriminated by the unit_of_assessment field.",
  "$defs": {
    "FeatureReport": {
      "properties": {
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "framework_id": {
          "const": "ai-product-pulse",
          "default": "ai-product-pulse",
          "title": "Framework Id",
          "type": "string"
        },
        "framework_version": {
          "title": "Framework Version",
          "type": "string"
        },
        "unit_of_assessment": {
          "const": "feature",
          "default": "feature",
          "title": "Unit Of Assessment",
          "type": "string"
        },
        "subject_name": {
          "title": "Subject Name",
          "type": "string"
        },
        "subject_description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Description"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "generated_by_harness": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated By Harness"
        },
        "layers": {
          "items": {
            "$ref": "#/$defs/LayerResult"
          },
          "title": "Layers",
          "type": "array"
        },
        "overall_score": {
          "maximum": 5,
          "minimum": 1,
          "title": "Overall Score",
          "type": "number"
        },
        "maturity_level": {
          "maximum": 5,
          "minimum": 1,
          "title": "Maturity Level",
          "type": "integer"
        },
        "verdicts": {
          "items": {
            "$ref": "#/$defs/VerdictResult"
          },
          "title": "Verdicts",
          "type": "array"
        },
        "vanity_metric_flags": {
          "items": {
            "type": "string"
          },
          "title": "Vanity Metric Flags",
          "type": "array"
        },
        "recommendations": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recommendations"
        }
      },
      "required": [
        "framework_version",
        "subject_name",
        "layers",
        "overall_score",
        "maturity_level",
        "verdicts"
      ],
      "title": "FeatureReport",
      "type": "object"
    },
    "IndicatorEvidence": {
      "properties": {
        "indicator_id": {
          "title": "Indicator Id",
          "type": "string"
        },
        "tracked": {
          "title": "Tracked",
          "type": "boolean"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        },
        "evidence_note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Note"
        },
        "risk_threshold_exceeded": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Risk Threshold Exceeded"
        }
      },
      "required": [
        "indicator_id",
        "tracked"
      ],
      "title": "IndicatorEvidence",
      "type": "object"
    },
    "LayerResult": {
      "properties": {
        "layer_id": {
          "enum": [
            "model_performance",
            "product_behaviour",
            "business_outcome"
          ],
          "title": "Layer Id",
          "type": "string"
        },
        "score": {
          "maximum": 5,
          "minimum": 1,
          "title": "Score",
          "type": "integer"
        },
        "maturity_label": {
          "title": "Maturity Label",
          "type": "string"
        },
        "indicators": {
          "items": {
            "$ref": "#/$defs/IndicatorEvidence"
          },
          "title": "Indicators",
          "type": "array"
        },
        "evidence_summary": {
          "title": "Evidence Summary",
          "type": "string"
        }
      },
      "required": [
        "layer_id",
        "score",
        "maturity_label",
        "indicators",
        "evidence_summary"
      ],
      "title": "LayerResult",
      "type": "object"
    },
    "ProductReport": {
      "properties": {
        "report_id": {
          "title": "Report Id",
          "type": "string"
        },
        "framework_id": {
          "const": "ai-product-pulse",
          "default": "ai-product-pulse",
          "title": "Framework Id",
          "type": "string"
        },
        "framework_version": {
          "title": "Framework Version",
          "type": "string"
        },
        "unit_of_assessment": {
          "const": "product",
          "default": "product",
          "title": "Unit Of Assessment",
          "type": "string"
        },
        "subject_name": {
          "title": "Subject Name",
          "type": "string"
        },
        "subject_description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject Description"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "generated_by_harness": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Generated By Harness"
        },
        "features": {
          "items": {
            "$ref": "#/$defs/FeatureReport"
          },
          "title": "Features",
          "type": "array"
        },
        "product_overall_score": {
          "maximum": 5,
          "minimum": 1,
          "title": "Product Overall Score",
          "type": "number"
        },
        "product_maturity_level": {
          "maximum": 5,
          "minimum": 1,
          "title": "Product Maturity Level",
          "type": "integer"
        },
        "verdict_rollup": {
          "items": {
            "$ref": "#/$defs/VerdictResult"
          },
          "title": "Verdict Rollup",
          "type": "array"
        }
      },
      "required": [
        "framework_version",
        "subject_name",
        "features",
        "product_overall_score",
        "product_maturity_level",
        "verdict_rollup"
      ],
      "title": "ProductReport",
      "type": "object"
    },
    "VerdictResult": {
      "properties": {
        "verdict_id": {
          "title": "Verdict Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "severity": {
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Severity",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "layer_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Layer Id"
        },
        "feature_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Feature Name"
        }
      },
      "required": [
        "verdict_id",
        "name",
        "severity",
        "message"
      ],
      "title": "VerdictResult",
      "type": "object"
    }
  },
  "discriminator": {
    "mapping": {
      "feature": "#/$defs/FeatureReport",
      "product": "#/$defs/ProductReport"
    },
    "propertyName": "unit_of_assessment"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/FeatureReport"
    },
    {
      "$ref": "#/$defs/ProductReport"
    }
  ]
}
